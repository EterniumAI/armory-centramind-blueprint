# ─── Supabase (optional) ─────────────────────────────────────────────────
# CentraMind works without Supabase. If you set these, the onboarding
# lead-capture form persists signups, and future versions of the
# Sessions / CRM tabs can pull from Postgres in addition to disk state.
#
# Get these at https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Eternium API (recommended for the Chat tab) ─────────────────────────
# The Chat tab in your CentraMind talks to Eternium's reseller API. You
# get this key when you buy the CentraMind template. It powers the in-
# dashboard chat agent without you needing your own OpenAI / Anthropic
# key. Pay-as-you-go via prepaid credits. 1 credit = $0.005.
#
# Buy / top up credits: https://eternium.ai/credits/topup
#
# This is read SERVER-SIDE only (by api/chat.js Pages Function) so the
# token never reaches the browser. Do not expose it via VITE_*.
ETERNIUM_API_KEY=
